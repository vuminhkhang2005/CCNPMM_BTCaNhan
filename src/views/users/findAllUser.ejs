<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Find All Users - Vũ Minh Khang 23110238</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
</head>
<body>
<div class="container mt-4">
    <h2>All Users - Vũ Minh Khang - MSSV: 23110238</h2>
    <table style="width:100%" class="table table-bordered table-striped">
        <tr>
            <th>Email</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Address</th>
            <th>Action</th>
        </tr>
        <% for(let i=0; i < datalist.length; i++) { %>
        <tr>
            <td><%= datalist[i].email %></td>
            <td><%= datalist[i].firstName %></td>
            <td><%= datalist[i].lastName %></td>
            <td><%= datalist[i].address %></td>
            <td><a href="/edit-crud?id=<%= datalist[i].id %>">Edit</a>||<a
                    href="/delete-crud?id=<%= datalist[i].id %>">Delete</a></td>
        </tr>
        <% } %>
    </table>
</div>
</body>
</html>
